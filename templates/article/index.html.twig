{% extends 'base.html.twig' %}

{% block body %}

<h1>Articles</h1>
<div class="grid grid-3">
    {% for article in articles %}
    <div class="article-card">
        <h2 class="title">{{ article.title }}</h2>
        <p class="content">{{ article.content|length > 50 ? article.content|slice(0, 50) ~ '...' : article.content  }}</p>
        <a href="{{ path('article_show_user', {'id': article.author.id}) }}" class="author-link">
            <p class="author">{{ article.author.name }}</p>
        </a>
    </div>
    {% endfor %}
</div>
{% endblock %}
